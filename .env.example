### Postgres
POSTGRES_DB=taskme
POSTGRES_USER=taskme
POSTGRES_PASSWORD=taskme_password_change_me
POSTGRES_HOST=db
POSTGRES_PORT=5432

### Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql+psycopg://taskme:taskme_password_change_me@db:5432/taskme

### JWT
JWT_SECRET_KEY=change_me_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

### Rate limiting
LOGIN_RATE_LIMIT=10/minute

### Logging
LOG_LEVEL=INFO
LOG_DIR=/app/logs

### Frontend (Reflex)
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000
REFLEX_BACKEND_PORT=3001
API_BASE_URL=http://backend:8000

### Seed (required for seed.py)
SEED_CEO_USERNAME=ceo
SEED_CEO_PASSWORD=ceo123
SEED_EMP1_USERNAME=emp1
SEED_EMP1_PASSWORD=emp123
SEED_EMP2_USERNAME=emp2
SEED_EMP2_PASSWORD=emp123
